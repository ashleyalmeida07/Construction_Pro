{
  "info": {
    "name": "Construction API",
    "_postman_id": "construction-api-collection",
    "description": "All endpoints for the Construction Management API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ashley\",\n  \"email\": \"ashley@example.com\",\n  \"password\": \"pass123\",\n  \"role\": \"admin\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.collectionVariables.set('token', res.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ashley@example.com\",\n  \"password\": \"pass123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "Get All Projects",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/projects",
              "host": ["{{baseUrl}}"],
              "path": ["projects"]
            }
          }
        },
        {
          "name": "Get All Projects (filter by status)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/projects?status=active",
              "host": ["{{baseUrl}}"],
              "path": ["projects"],
              "query": [
                { "key": "status", "value": "active" }
              ]
            }
          }
        },
        {
          "name": "Get Project by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/projects/1",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "1"]
            }
          }
        },
        {
          "name": "Create Project",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/projects", "host": ["{{baseUrl}}"], "path": ["projects"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Bridge Construction\",\n  \"description\": \"Phase 1 of the river bridge project\",\n  \"start_date\": \"2026-03-01\",\n  \"end_date\": \"2026-12-31\",\n  \"status\": \"active\"\n}"
            }
          }
        },
        {
          "name": "Update Project",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/projects/1", "host": ["{{baseUrl}}"], "path": ["projects", "1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Bridge Construction (Updated)\",\n  \"status\": \"completed\"\n}"
            }
          }
        },
        {
          "name": "Delete Project",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/projects/1", "host": ["{{baseUrl}}"], "path": ["projects", "1"] }
          }
        }
      ]
    },
    {
      "name": "Daily Progress Reports",
      "item": [
        {
          "name": "Get DPRs for Project",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/projects/1/dpr", "host": ["{{baseUrl}}"], "path": ["projects", "1", "dpr"] }
          }
        },
        {
          "name": "Create DPR",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/projects/1/dpr", "host": ["{{baseUrl}}"], "path": ["projects", "1", "dpr"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"date\": \"2026-03-12\",\n  \"work_description\": \"Foundation poured on east wing\",\n  \"weather\": \"Sunny, 30°C\",\n  \"worker_count\": 22\n}"
            }
          }
        },
        {
          "name": "Delete DPR",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/projects/1/dpr/1", "host": ["{{baseUrl}}"], "path": ["projects", "1", "dpr", "1"] }
          }
        }
      ]
    }
  ]
}
